# Required
OPENAI_API_KEY=sk-your-openai-api-key

# Optional - API auth (empty = dev mode, no auth)
API_KEY=your-api-key

# Required for /admin/ingest and /admin/ingest-from-source
ADMIN_API_KEY=your-admin-key

# JWT for session auth (login). Set a strong secret in production.
# After migration 011: run `make create-admin` or `python -m scripts.create_admin_user`
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=10080

# Production: restrict CORS and hide API docs
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
# DOCS_ENABLED=false

# Optional - override defaults
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/support_ai
# REDIS_URL=redis://localhost:6379/0
# OPENSEARCH_HOST=http://localhost:9200
# QDRANT_HOST=localhost

# Reranker: local (needs http://localhost:8001), cohere (needs COHERE_API_KEY), or custom (no-op, use when no reranker service)
# RERANKER_PROVIDER=custom

# Retrieval (strong RAG: RRF fusion)
# RETRIEVAL_TOP_N=100   # per source (BM25 + vector) before merge/rerank; raise carefully for recall vs latency
# RETRIEVAL_FUSION=rrf
# RETRIEVAL_RRF_K=60

# Intent-aware fetch: for plans/price queries, also fetch from these doc_types
# RETRIEVAL_PLANS_FETCH_DOC_TYPES=pricing
# Policy/refund/terms: doc types to filter. Empty = search all (no filter). E.g. RETRIEVAL_POLICY_DOC_TYPES=policy,tos
# RETRIEVAL_POLICY_DOC_TYPES=
# RETRIEVAL_ENSURE_DOC_TYPE_MIN=2
# RETRIEVAL_CONVERSATION_SCORE_PENALTY=0.55  (0.55 = 45%% penalty; prefer docs, use conversation when docs lack ideal chunks)
# page_kind_filter_enabled: configure in Settings UI (Archi v3). Default false until re-ingest with page_kind.

# Doc type classifier: use LLM to classify crawled docs from content (policy, tos, faq, howto, pricing, other)
# Prefer Settings UI (stored in DB). Env fallback when DB empty.
# DOC_TYPE_CLASSIFIER_ENABLED=false

# Prompt layering: Core + Domain + Custom (internal bot, not multi-tenant)
# PROMPT_DOMAIN=support  (support | legal | generic). Also via PUT /admin/config/prompt_domain
# Custom rules via PUT /admin/config/custom_prompt_rules
# Config-driven URL doc_type inference map (doc_type -> keyword list)
# DOC_TYPE_URL_KEYWORDS={"tos":["terms","tos"],"policy":["privacy","policy"],"faq":["faq","faqs"],"howto":["docs","documentation","help"],"pricing":["vps","billing","store","pricing"]}

# WHMCS crawler (sample conversations). Set base URL to pre-fill Crawler UI.
# WHMCS_BASE_URL=https://example.com/billing
# WHMCS_LIST_PATH=supporttickets.php?filter=1
# WHMCS_LOGIN_PATH=login.php

# LLM (stored in DB app_config; env used as fallback when DB empty)
# Edit via Settings UI or PUT /admin/config/llm
# LLM_MODEL=gpt-5.2
# LLM_FALLBACK_MODEL=gpt-3.5-turbo
# LLM_MODEL_ECONOMY=gpt-4o-mini  (normalizer, decision_router, evidence_evaluator, final_polish)
# LLM_TASK_AWARE_ROUTING_ENABLED=true  (primary for generate/self_critic, economy for rest)
# OPENAI_API_KEY=sk-...  (also used as llm_api_key when not in DB)
# OPENAI_BASE_URL=      (optional; empty = default OpenAI URL)

# Pipeline logging: log each RAG stage (answer_service, retrieve, assess, decide, generate, verify)
# PIPELINE_LOGGING_ENABLED=true
# Intent keys that must not bypass RAG
# INTENT_CACHE_DISABLED_KEYS=["refund_policy"]

# Query Rewriter (Phase 2: LLM when QuerySpec absent)
# QUERY_REWRITER_USE_LLM=true
# QUERY_REWRITER_CACHE_ENABLED=true
# QUERY_REWRITER_CACHE_TTL_SECONDS=3600

# Evidence Selector (Phase 1: coverage-aware selection)
# EVIDENCE_SELECTOR_USE_LLM=true
# EVIDENCE_SELECTOR_FALLBACK_TOP_K=8
# EvidenceSet fallback matching (used only when LLM coverage_map is absent)
# EVIDENCE_REQUIREMENT_KEYWORDS={"transaction_link":["http","www.","order","store"],"has_any_url":["http","www.","order","store"],"policy_language":["policy","terms","refund","eligible"],"steps_structure":["step","1.","2.","first","second","then"]}
# EVIDENCE_REQUIREMENT_REGEX_PATTERNS={"numbers_units":"\\d+(\\s*%|\\s*usd|\\s*vnd|\\s*\\$|/mo)"}

# Config-driven reviewer/claim/hygiene patterns (JSON arrays)
# REVIEWER_HIGH_RISK_PATTERNS=["\\b(refund|reimburse|money back)\\b","\\b(billing|invoice|payment dispute)\\b","\\b(legal|lawsuit|attorney)\\b","\\b(abuse|fraud|violation)\\b","\\b(cancel.*subscription|terminate)\\b"]
# REVIEWER_POLICY_DOC_TYPES=["policy","tos"]
# REVIEWER_POLICY_CLAIM_PATTERNS=["according to (?:our |the )?policy","(?:we |the company )?(?:shall|must|may not)","within \\d+ (?:days|hours)","(?:eligible|entitled) (?:for|to)"]
# CLAIM_PARSER_POLICY_PATTERNS=["according to (?:our |the )?policy","(?:we |the company )?(?:shall|must|may not)","within \\d+ (?:days|hours)","(?:eligible|entitled) (?:for|to)","refund|reimburse|money back"]
# HYGIENE_BOILERPLATE_PATTERNS=["\\bcontact\\s+(?:us|support)\\b","\\bcopyright\\s+(?:\\u00A9)?\\s*\\d{4}","\\b(?:privacy|terms)\\s+(?:of\\s+)?(?:service|policy)\\b","\\bmenu\\b","\\ball\\s+rights\\s+reserved\\b","\\bsign\\s+(?:in|up)\\b","\\blogin\\b","\\bcart\\b","\\bcheckout\\b","\\bnav(?:igation)?\\b","\\bfooter\\b","\\bcookie\\s+policy\\b"]
# HYGIENE_TRANSACTION_PATH_PATTERNS=["/(?:order|store|checkout|cart|buy|purchase|subscribe|billing)/?","/(?:dedicated-servers|proxies|semi-dedicated|vps)/?","(?:dedicated-servers|proxies|semi-dedicated|-vps|vps|billing)\\.(?:php|html?)","order_link","order\\s*link"]

# archi_v3
# LANGUAGE_DETECT_ENABLED=true
# NORMALIZER_USE_LLM=false
# NORMALIZER_LLM_MODEL=gpt-4o-mini
# NORMALIZER_DOMAIN_TERMS=   (comma-separated entity terms, e.g. vps,windows,linux,pricing)
# NORMALIZER_SLOTS_ENABLED=false
# NORMALIZER_SLOT_PRODUCT_TYPES=   (e.g. vps,dedicated,vds for hosting; plan_a,plan_b for SaaS. Empty = disabled)
# NORMALIZER_SLOT_OS_TYPES=   (e.g. windows,linux,macos. Empty = disabled)
# EVIDENCE_EVALUATOR_ENABLED=false
# SELF_CRITIC_ENABLED=false
# SELF_CRITIC_REGENERATE_MAX=1
# FINAL_POLISH_ENABLED=false
# DECISION_ROUTER_USE_LLM=false
# DECISION_ROUTER_LLM_MODEL=gpt-4o-mini
